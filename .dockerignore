# The image only needs pyproject.toml + services/ (see Dockerfile).
# Everything else just bloats the build context — exclude it.
.git
.github
.gitignore
.dockerignore
*.md
docs/
tests/
workers/
deploy/
scripts/
.env
.env.*
.venv/
**/__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
docker-compose.yml
